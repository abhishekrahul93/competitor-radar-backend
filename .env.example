# Competitor Radar AI — Backend Environment Variables

# Database (Railway sets this automatically when you add PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/competitor_radar

# Security (CHANGE THESE IN PRODUCTION)
SECRET_KEY=generate-a-random-64-char-string-here
JWT_SECRET=generate-another-random-64-char-string-here

# Frontend URL (update with your Vercel URL)
CORS_ORIGINS=["http://localhost:5173","https://competitor-radar.vercel.app"]

# AI Provider: "openai" or "anthropic"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=

# AI Model
AI_MODEL=gpt-4o-mini
